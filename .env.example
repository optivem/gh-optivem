# gh-optivem credentials — sample template.
#
# gh-optivem loads a user-level .env at startup so you don't have to set six
# OS environment variables and restart your terminal / VS Code every time.
#
# Setup:
#   1. Copy this file and fill in the real values:
#        cp .env.example my.env
#   2. Drop it at the user path gh-optivem reads:
#        Windows: %AppData%\gh-optivem\.env
#        Linux/mac: ~/.config/gh-optivem/.env
#      …or keep it in a synced folder (Dropbox/OneDrive) and point at it with:
#        export GH_OPTIVEM_ENV_FILE=/path/to/my.env
#   3. Edit it any time — no terminal restart needed.
#
# Precedence: a real exported environment variable always wins; the file only
# fills variables that are currently unset. Never commit your filled-in copy —
# `.env` is gitignored; only this `.env.example` template is tracked.

# Docker Hub account name (the username, not a token) that owns DOCKERHUB_TOKEN.
DOCKERHUB_USERNAME=your-dockerhub-username

# Docker Hub Personal Access Token. The scaffolded repo's stages use it to pull
# base images. Create one at:
#   https://app.docker.com/settings/personal-access-tokens
DOCKERHUB_TOKEN=your-dockerhub-token

# SonarCloud token, used for the local and CI code-quality scans. Generate at:
#   https://sonarcloud.io/account/security
SONAR_TOKEN=your-sonarcloud-token

# GitHub Personal Access Token (classic) with write:packages + read:packages.
# The scaffolded repo's acceptance/prod stages use it to tag images in GHCR.
#   https://github.com/settings/tokens
GHCR_TOKEN=your-ghcr-token

# GitHub Personal Access Token (classic) with repo + workflow scopes. The
# scaffolded repo's acceptance/QA/prod stages use it to push release tags
# (the default GITHUB_TOKEN cannot push tags whose commit diffs workflow files).
#   https://github.com/settings/tokens
WORKFLOW_TOKEN=your-workflow-token

# GitHub Personal Access Token (classic) with repo scope — OR a fine-grained PAT
# with Contents:Read on the component repos. In multitier+multirepo scaffolds,
# the system-level prod-stage uses it to read each component repo's VERSION file.
#   https://github.com/settings/tokens
REPO_TOKEN=your-repo-token
